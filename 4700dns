#!/usr/bin/env -S python3 -u

import argparse, socket, time, select, sys, threading
from collections import defaultdict
from dnslib import DNSRecord, DNSHeader, DNSQuestion, RR, QTYPE, RCODE

"""
Thread-safe DNS cache keyed by name and type
"""
class Cache:
    def __init__(self):
        self.lock = threading.Lock()
        self.store = {}

    """
    Normalize a name to lowercase with a trailing dot for consistent keying
    """
    def _norm(self, name) -> str:
        s = str(name).lower()
        return s if s.endswith('.') else s + '.'

    """
    Add a record to the cache skipping non-positive TTLs and deduping rdata
    """
    def put(self, rr):
        try:
            ttl = int(rr.ttl)
        except Exception:
            return
        if ttl <= 0:
            return
        key = (self._norm(rr.rname), rr.rtype)
        expiry = time.time() + ttl
        rdata_sig = str(rr.rdata)
        with self.lock:
            existing = self.store.get(key, [])
            existing = [(r, e) for (r, e) in existing if str(r.rdata) != rdata_sig]
            existing.append((rr, expiry))
            self.store[key] = existing

    """
    Return RR copies for the given name/type with TTLs recomputed to now minus expiry time
    without expired entries and returns an empty list if no valid entries are found
    """
    def get(self, name, qtype):
        key = (self._norm(name), qtype)
        now_t = time.time()
        with self.lock:
            entries = self.store.get(key, [])
            valid = [(r, e) for (r, e) in entries if e > now_t]
            if not valid:
                self.store.pop(key, None)
                return []
            self.store[key] = valid
        out = []
        for r, e in valid:
            remaining = max(1, int(e - now_t))
            out.append(RR(rname=r.rname, rtype=r.rtype, rclass=r.rclass,
                          ttl=remaining, rdata=r.rdata))
        return out

    """
    Return zone and ips of the closest cached parent zone of name that has
    both NS records and matching A glue rec
    """
    def best_ns(self, name):
        n = self._norm(name).rstrip('.')
        if not n:
            return None, None
        parts = n.split('.')
        for i in range(len(parts)):
            zone = '.'.join(parts[i:]) + '.'
            ns_records = self.get(zone, QTYPE.NS)
            if not ns_records:
                continue
            ips = []
            for ns in ns_records:
                try:
                    host = self._norm(ns.rdata.label)
                except Exception:
                    continue
                for a in self.get(host, QTYPE.A):
                    ips.append(str(a.rdata))
            if ips:
                return zone, ips
        return None, None


class Server:
    def __init__(self, root_ip, zone_file, port):
        self.root_ip = root_ip
        self.zone_file = zone_file

        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.socket.bind(("127.0.0.1", port))
        self.port = self.socket.getsockname()[1]

        print("Bound to port %d" % self.port, flush=True)

        # Parse zone file + initialize records and auth domain
        self.parse_zone_file(zone_file)

        # Cache for upstream answers, auth, and additional records
        self.cache = Cache()

    def log(self, message):
        sys.stderr.write(message + "\n")
        sys.stderr.flush()

    def send(self, addr, message):
        self.log("Sending message:\n%s" % message)
        self.socket.sendto(message.pack(), addr)
    
    """
    Normalize a domain name for case insensitivity and trailing dot
    """
    def normalize_name(self, name) -> str:
        s = str(name).lower()
        return s if s.endswith('.') else s + '.'

    """
    This function checks if a provided domain name is in the zone of the server
    True if qname is our authoritative domain or a subdomain
    """
    def is_in_zone(self, qname: str) -> bool:
        return qname == self.auth_domain or qname.endswith("." + self.auth_domain)

    """
    True if name is equal to or a subdomain of bailiwick
    """
    def in_bailiwick(self, name, bailiwick) -> bool:
        n = self.normalize_name(name)
        b = self.normalize_name(bailiwick)
        if b == '.':
            return True
        return n == b or n.endswith('.' + b)

    """
    Drop records outside the responding server's bailiwick from response
    """
    def filter_bailiwick(self, response, bailiwick):
        response.rr = [r for r in response.rr if self.in_bailiwick(r.rname, bailiwick)]
        response.auth = [r for r in response.auth if self.in_bailiwick(r.rname, bailiwick)]
        response.ar = [r for r in response.ar if self.in_bailiwick(r.rname, bailiwick)]
        # keep header section counts synced after filtering
        try:
            response.set_header_qa()
        except Exception:
            response.header.a = len(response.rr)
            response.header.auth = len(response.auth)
            response.header.ar = len(response.ar)

    """
    Build a DNS response from given records
    used for cache hits and splicing a CNAME chain onto the final answer
    """
    def create_res(self, qname, qtype, answers, auth=None, ar=None,
                       rcode=RCODE.NOERROR):
        response = DNSRecord(DNSHeader(qr=1, ra=1, rd=1, rcode=rcode),
                             q=DNSQuestion(qname, qtype))
        for rr in answers:
            response.add_answer(rr)
        if auth:
            for rr in auth:
                response.add_auth(rr)
        if ar:
            for rr in ar:
                response.add_ar(rr)
        return response

    """
    This function adds glue records for NS answers to the response
    """
    def add_glue_for_ns_answers(self, response, ns_rrs):
        seen = set()
        for rr in ns_rrs:
            # only add glue for NS records
            if rr.rtype != QTYPE.NS:
                continue
            try:
                host = self.normalize_name(rr.rdata.label)
            except Exception:
                self.log("error: bad NS hostname in glue")
                continue
            # only add glue for NS records that are in our zone
            if not self.is_in_zone(host):
                continue
            # add glue for A and AAAA records
            for t in (QTYPE.A, QTYPE.AAAA):
                # get all glue records for the host and type
                for glue in self.records.get((host, t), []):
                    # only add glue record to response if it hasn't been added yet
                    glue_record = (self.normalize_name(glue.rname), glue.rtype, str(glue.rdata))
                    if glue_record in seen:
                        continue
                    seen.add(glue_record)
                    response.add_ar(glue)

    """
    This function handles the case where query is for within our authoritative domain
    It doesn't need to make any queries to other servers and can just return answers
    straight from stored records
    """
    def handle_in_domain(self, request):
        qname = self.normalize_name(request.q.qname)
        qtype = request.q.qtype
        response = request.reply()
        response.header.aa = 1 # set to 1 b/c query is about authoritative domain

        # Check if there are any answers in our saved records for the query
        answers = self.records.get((qname, qtype), [])
        if answers:
            for rr in answers:
                response.add_answer(rr) 
            if qtype == QTYPE.NS:
                self.add_glue_for_ns_answers(response, answers)
            return response

        if qtype not in (QTYPE.NS, QTYPE.SOA, QTYPE.CNAME):
            visited = set()
            cur = qname
            max_depth = 10

            # Follow CNAME chains up to the max depth
            for _ in range(max_depth):
                if cur in visited:
                    break
                visited.add(cur)

                # Get CNAME records for the current domain
                cnames = self.records.get((cur, QTYPE.CNAME), [])

                
                if not cnames:
                    break

                # add CNAME records to response
                for rr in cnames:
                    response.add_answer(rr)
                
                # Get the target domain from the CNAME record
                try:
                    target = self.normalize_name(cnames[0].rdata.label)
                except Exception:
                    self.log("error: bad CNAME target in zone")
                    break

                # If CNAME points outside our zone, recursively resolve
                # the rest of the chain so the client still gets an answer
                if not self.is_in_zone(target):
                    if qtype != QTYPE.CNAME and request.header.rd == 0:
                        response.header.rcode = RCODE.SERVFAIL
                        return response
                    if qtype != QTYPE.CNAME and request.header.rd == 1:
                        sub = self.resolve_recursive(target, qtype)
                        if sub is not None and sub.header.rcode == RCODE.NOERROR:
                            for rr in sub.rr:
                                # don't duplicate CNAMEs already added
                                if rr.rtype == QTYPE.CNAME and any(
                                        self.normalize_name(a.rname) ==
                                        self.normalize_name(rr.rname) and
                                        a.rtype == QTYPE.CNAME
                                        for a in response.rr):
                                    continue
                                response.add_answer(rr)
                    return response
                
                # Get the answers for the target domain
                target_answers = self.records.get((target, qtype), [])
                if target_answers:
                    for rr in target_answers:
                        response.add_answer(rr)
                    return response

                cur = target

        # if name exists in zone but not this record type 
        if qname in self.zone_owner_names:
            response.header.rcode = RCODE.NOERROR
            return response
        response.header.rcode = RCODE.NXDOMAIN
        return response

    """
    This function handles the case where query is for outside our authoritative domain
    It needs to make queries to other servers to resolve the query
    """
    def handle_out_domain(self, request):
        qname = self.normalize_name(request.q.qname)
        qtype = request.q.qtype

        # the query request doesn't want recursion, so we just return SERVFAIL
        if request.header.rd == 0:
            response = request.reply()
            response.header.rcode = RCODE.SERVFAIL
            return response

        resolved = self.resolve_recursive(qname, qtype)

        # build reply off the request so question/ID/RD always match
        response = request.reply()
        response.header.ra = 1 # recursion available
        response.header.aa = 0 # not authoritative
        response.header.tc = 0 # not truncated

        if resolved is None:
            response.header.rcode = RCODE.SERVFAIL
            return response

        response.header.rcode = resolved.header.rcode
        for rr in resolved.rr:
            response.add_answer(rr)
        for rr in resolved.auth:
            response.add_auth(rr)
        for rr in resolved.ar:
            response.add_ar(rr)
        return response

    """
    Helper function to query a server for a record.
    Given a server IP address, a query name, and a query type,
    it sends a query to the server and returns the response
    through UDP on port 60053
    """
    def query_server(self,server, qname, qtype, timeout=1.0):
        q = DNSRecord.question(qname, QTYPE[qtype])
        q.header.rd = 0

        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        try:
            sock.settimeout(timeout)
            sock.sendto(q.pack(), (server, 60053))
            data, _ = sock.recvfrom(65535)
            return DNSRecord.parse(data)
        except (socket.timeout, OSError):
            self.log("error: query timeout or network error")
            return None
        except Exception:
            self.log("error: query failed")
            return None
        finally:
            try:
                sock.close()
            except Exception:
                self.log("error: socket close failed")


    """
    This function recursively resolves a query by querying other servers
    The function effectively loops through a set of actions:
    - Check the cache for a direct answer or CNAME for the qname
    - Pick the closest cached parent zone as a starting point, else root
    - Send iterative queries to servers, filtering each response by the
    responding server's bailiwick before trusting or caching records
    - Follow CNAME chains (with a visited set to detect loops),
    accumulating the chain so the final answer includes it
    - Follow NS referrals using glue A records or by resolving the NS
    hostname if glue records not found
    - Get a final answer from whichever server has it and return it
    """
    def resolve_recursive(self, qname, qtype, depth=0, cname_chain=None):
        # set a recursion depth limitso a malicious chain can't loop forever
        if depth > 16:
            return None
        if cname_chain is None:
            cname_chain = []
        qname = self.normalize_name(qname)

        # cache hit for the asked type
        cached = self.cache.get(qname, qtype)
        if cached:
            # for NS answers also pull A glue from cache for each NS host
            glue = []
            if qtype == QTYPE.NS:
                for ns in cached:
                    try:
                        host = self.normalize_name(ns.rdata.label)
                    except Exception:
                        continue
                    for a in self.cache.get(host, QTYPE.A):
                        glue.append(a)
            return self.create_res(qname, qtype, list(cname_chain) + cached,
                                       ar=glue if glue else None)

        # cache hit for a CNAME on this name so we chase target
        if qtype != QTYPE.CNAME:
            cached_cname = self.cache.get(qname, QTYPE.CNAME)
            if cached_cname:
                try:
                    target = self.normalize_name(cached_cname[0].rdata.label)
                except Exception:
                    target = None
                if target is not None:
                    if any(self.normalize_name(c.rname) == target for c in cname_chain):
                        return self.create_res(qname, qtype,
                                                   list(cname_chain) + cached_cname)
                    return self.resolve_recursive(target, qtype, depth + 1,
                                                  list(cname_chain) + cached_cname)

        # use closest cached parent zone if we know one else root
        zone, cached_ips = self.cache.best_ns(qname)
        if cached_ips:
            servers = list(cached_ips)
            bailiwicks = [zone] * len(cached_ips)
        else:
            servers = [self.root_ip]
            bailiwicks = ['.']

        while servers:
            server_ip = servers.pop(0)
            bailiwick = bailiwicks.pop(0)

            response = self.query_server(server_ip, qname, qtype)
            # if no response from curr server try next server if it exists
            if response is None:
                continue

            # drop records outside the responding server's bailiwick
            self.filter_bailiwick(response, bailiwick)

            # cache surviving records, but only on a successful response
            if response.header.rcode == RCODE.NOERROR:
                for rr in list(response.rr) + list(response.auth) + list(response.ar):
                    self.cache.put(rr)

            # if response is error, return response
            if response.header.rcode != RCODE.NOERROR:
                return response

            # if we got the requested answer type with the correct name, return response
            # NS answers may appear either in the answer or authority sections
            if any(
                self.normalize_name(rr.rname) == qname and rr.rtype == qtype
                for rr in list(response.rr) + list(response.auth)
            ):
                if cname_chain:
                    return self.create_res(qname, qtype,
                                               list(cname_chain) + list(response.rr),
                                               auth=list(response.auth),
                                               ar=list(response.ar))
                return response

            # if we got CNAME, recurse on the target with chain accumulated
            cname_rr = None
            target = None
            for rr in response.rr:
                if self.normalize_name(rr.rname) == qname and rr.rtype == QTYPE.CNAME:
                    try:
                        target = self.normalize_name(rr.rdata.label)
                        cname_rr = rr
                    except Exception:
                        self.log("error: bad CNAME in server response")
                        continue
                    break
            if target is not None:
                if any(self.normalize_name(c.rname) == target for c in cname_chain):
                    return None
                return self.resolve_recursive(target, qtype, depth + 1,
                                              list(cname_chain) + [cname_rr])

            # if referred to another server, add NS IPs to servers to query next
            ns_names = []
            ns_zone = None
            # check both authority and answer sections for NS records
            for rr in list(response.auth) + list(response.rr):
                if rr.rtype == QTYPE.NS:
                    try:
                        ns_names.append(self.normalize_name(rr.rdata.label))
                        if ns_zone is None:
                            ns_zone = self.normalize_name(rr.rname)
                    except Exception:
                        self.log("error: bad NS hostname in referral")
                        continue
            if not ns_names:
                # no referral or answer so return what we have
                if cname_chain:
                    return self.create_res(qname, qtype,
                                               list(cname_chain) + list(response.rr),
                                               auth=list(response.auth),
                                               ar=list(response.ar))
                return response

            # next bailiwick is the delegated zone
            new_bw = ns_zone if ns_zone else bailiwick

            # if there are glue records (in ADDITIONAL section), we can get
            # IP addresses of the NS servers and we can use them in future
            # queries
            ns_set = set(ns_names)
            glue_ips = []
            # check all records in ADDITIONAL section of server response
            # if it is A record and the owner is a NS server,
            # add the IP address to the list of glue IPs
            for rr in response.ar:
                if rr.rtype == QTYPE.A:
                    owner = self.normalize_name(rr.rname)
                    if owner in ns_set:
                        glue_ips.append(str(rr.rdata))
            if glue_ips:
                servers = glue_ips
                bailiwicks = [new_bw] * len(glue_ips)
                continue

            # no glue records so we need to resolve the NS hostname to an IP
            # try cache first, then fall back to a recursive lookup
            ns_ip = None
            for ns_name in ns_names:
                cached_a = self.cache.get(ns_name, QTYPE.A)
                if cached_a:
                    ns_ip = str(cached_a[0].rdata)
                    break
            if ns_ip is None:
                ns_resp = self.resolve_recursive(ns_names[0], QTYPE.A, depth + 1)
                if ns_resp is None:
                    return None
                # pick first A record in answer section
                for rr in ns_resp.rr:
                    if (self.normalize_name(rr.rname) == self.normalize_name(ns_names[0])
                            and rr.rtype == QTYPE.A):
                        ns_ip = str(rr.rdata)
                        break
            if ns_ip is None:
                return None

            servers = [ns_ip]
            bailiwicks = [new_bw]

        return None

    # changed to handle_req so that server can handle multiple requests at once
    def handle_req(self, data, addr):
        # Unpack the DNS request
        try:
            request = DNSRecord.parse(data)
        except Exception:
            self.log("error: malformed DNS packet")
            return
        self.log("Received message:\n%s" % request)

        # rej requests from non-local clients
        if addr[0] != "127.0.0.1":
            response = request.reply()
            response.header.rcode = RCODE.REFUSED
            self.send(addr, response)
            return

        if len(request.questions) != 1:
            response = request.reply()
            response.header.rcode = RCODE.SERVFAIL
            self.send(addr, response)
            return

        qname = self.normalize_name(request.q.qname)
        if self.is_in_zone(qname):
            response = self.handle_in_domain(request)
            self.send(addr, response)
            return

        response = self.handle_out_domain(request)
        self.send(addr, response)

    """
    This function receives a request from a client and handles it
    using a background thread so that the server can handle multiple requests at once
    """
    def recv(self, socket):
        data, addr = socket.recvfrom(65535)
        t = threading.Thread(target=self.handle_req, args=(data, addr))
        t.start()

    """
    This function parses the zone file and initializes the server's records
    """
    def parse_zone_file(self, zone_file):
        zone_txt = open(zone_file, 'r', encoding='utf-8').read()
        zone_RRs = RR.fromZone(zone_txt)
        self.records = defaultdict(list)
        self.auth_domain = None
        self.zone_owner_names = set()
        for r in zone_RRs:
            if r.rtype == QTYPE.SOA and self.auth_domain is None:
                self.auth_domain = self.normalize_name(r.rname)
            owner = self.normalize_name(r.rname)
            self.zone_owner_names.add(owner)
            self.records[(owner, r.rtype)].append(r)

    def run(self):
        seq = 0
        while True:
            socks = select.select([self.socket], [], [], 0.1)[0]
            for conn in socks:
                self.recv(conn)

        return

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='send data')
    parser.add_argument('root_ip', type=str, help="The IP address of the root server")
    parser.add_argument('zone', type=str, help="The zone file for this server")
    parser.add_argument('--port', type=int, help="The port this server should bind to", default=0)
    args = parser.parse_args()
    sender = Server(args.root_ip, args.zone, args.port)
    sender.run()
